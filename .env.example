# Copy this file to `.env` and fill in the values. NEVER commit your real `.env`.
# (.env is already git-ignored.)

# ───────────────── Required for LIVE matching (real Claude API calls) ─────────────────
# Create/rotate a key at https://console.anthropic.com/
# Treat any key that has ever appeared in a transcript or chat as burned — rotate it.
ANTHROPIC_API_KEY=

# ───────────────── Planned deployment vars (NOT yet wired into the code) ─────────────────
# These are documented here for the Render deployment described in the audit.
# They have no effect until the deployment work is approved and implemented.
#
# APP_MODE: "display" = serve saved results, ZERO API calls (use this for the shared link)
#           "live"    = run real matching (must be password-gated)
# APP_MODE=display
#
# LIVE_PASSWORD: required to start a run when APP_MODE=live (keeps a leaked link from burning spend)
# LIVE_PASSWORD=
#
# PORT: local dev port. Render injects its own PORT at runtime, so do not hardcode it.
# PORT=3000
